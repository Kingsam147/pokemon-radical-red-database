# MongoDB
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?appName=<appName>
MONGODB_DB=<database-name>

# Redis
REDIS_URL=redis://default:<password>@<host>:<port>

# Game data version — bump this (e.g. v2, v3) whenever MongoDB game data changes to bust client caches
DATA_VERSION=v1

# AWS S3
AWS_ACCESS_KEY_ID=<your-aws-access-key-id>
AWS_SECRET_ACCESS_KEY=<your-aws-secret-access-key>
AWS_REGION=<your-aws-region>
AWS_S3_BUCKET=<your-s3-bucket-name>

# Auth0 (Backend)
AUTH0_AUDIENCE=https://your-api-identifier
AUTH0_ISSUER_BASE_URL=https://your-tenant.auth0.com

# Guest identity
GUEST_COOKIE_SECRET=<generate-a-long-random-string>
CORS_ORIGIN=http://localhost:3000

# Sentry (Backend) — get DSN from https://sentry.io/settings/<org>/projects/<project>/keys/
SENTRY_DSN=https://<key>@<org>.ingest.us.sentry.io/<project-id>
SENTRY_ORG=<your-sentry-org-slug>
SENTRY_PROJECT=pokemon-radical-red
SENTRY_AUTH_TOKEN=<your-sentry-auth-token>

# Cloudflare
CLOUDFLARE_API_TOKEN=<your-cloudflare-api-token>
CLOUDFLARE_ACCOUNT_ID=<your-cloudflare-account-id>
