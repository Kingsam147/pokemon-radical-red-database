# Backend API URL (use http://localhost:3500 for local development)
NEXT_PUBLIC_API_URL=http://localhost:3500

# Auth0
NEXT_PUBLIC_AUTH0_DOMAIN=your-tenant.auth0.com
NEXT_PUBLIC_AUTH0_CLIENT_ID=your-client-id
NEXT_PUBLIC_AUTH0_AUDIENCE=https://your-api-identifier

# Sentry — get DSN from https://sentry.io/settings/<org>/projects/<project>/keys/
NEXT_PUBLIC_SENTRY_DSN=https://<key>@<org>.ingest.us.sentry.io/<project-id>
SENTRY_ORG=<your-sentry-org-slug>
SENTRY_PROJECT=pokemon-radical-red
SENTRY_AUTH_TOKEN=<your-sentry-auth-token>

# Cloudflare Web Analytics — get token from https://dash.cloudflare.com/<account>/web-analytics
NEXT_PUBLIC_CF_ANALYTICS_TOKEN=<your-cloudflare-analytics-token>
